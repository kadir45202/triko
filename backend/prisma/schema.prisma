// Triko veri şeması — geliştirmede SQLite, üretimde PostgreSQL.
// PostgreSQL'e geçiş: provider = "postgresql" yap, aşağıdaki iki SQLite
// uyarlamasını geri çevir:
//   - Customer.plan: String  → enum Plan { STARTER GROWTH ENTERPRISE }
//   - MascotSettings.noGoSelectors: String (JSON) → String[] @default([])

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  companyName   String
  token         String    @unique @default(cuid())
  plan          String    @default("STARTER") // STARTER | GROWTH | ENTERPRISE
  planExpiresAt DateTime?
  // Widget'ın çalışmasına izin verilen domain'ler (JSON dizi; boş = kısıtsız, demo modu)
  allowedDomains String   @default("[]")
  // Ajanın periyodik tarama yaptığı site adresi (Faz B aktif sinyal)
  siteUrl       String?
  // false → ajan kombinleri "pending" oluşturur, editör Onay Kuyruğu'ndan yayınlar
  autoPublishCombos Boolean @default(true)
  createdAt     DateTime  @default(now())

  mascotSettings MascotSettings?
  combos         Combo[]
  events         AnalyticsEvent[]
  products       Product[]
  agentEvents    AgentEvent[]
  scanRuns       ScanRun[]
}

// Ajanın keşfettiği ürün kataloğu (Faz A/B).
// source: jsonld (widget pasif sinyali) | crawl (sitemap taraması) | feed
// status: active | removed (sitede artık yok — kombinlerden düşürülür)
model Product {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  externalId String  // sitedeki ürün kimliği (JSON-LD sku/id veya URL'den türetilir)
  url        String
  name       String
  price      Float?
  currency   String  @default("TRY")
  imageUrl   String?
  rawCategory String?

  // AI zenginleştirme çıktıları
  category  String? // normalize: ust-giyim | alt-giyim | elbise | dis-giyim | ayakkabi | aksesuar | canta
  color     String?
  styleTags String  @default("[]") // JSON dizi: casual | ofis | gece | spor | plaj ...
  season    String? // yaz | kis | mevsimlik
  enriched  Boolean @default(false)

  source    String   @default("crawl")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, externalId])
  @@index([customerId, status])
}

// Ajan aktivite akışı — panelde "🤖 142 ürün keşfedildi..." beslemesi
model AgentEvent {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  type      String // scan_started | product_found | product_enriched | combo_created | product_removed | scan_finished | error
  message   String
  meta      String  @default("{}") // JSON detay
  createdAt DateTime @default(now())

  @@index([customerId, createdAt])
}

model MascotSettings {
  id         String   @id @default(cuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  imageUrl     String?
  primaryColor String  @default("#7c3aed")
  mascotName   String  @default("Triko")
  sizeDesktop  Int     @default(68)
  sizeMobile   Int     @default(52)

  proactiveDelayMs     Int     @default(6000)
  proactiveIntervalMs  Int     @default(50000)
  proximityThresholdPx Int     @default(150)
  maxDailyShows        Int     @default(12)
  mobileEnabled        Boolean @default(true)

  noGoSelectors String   @default("[]") // JSON dizi — Postgres'te String[]
  updatedAt     DateTime @updatedAt
}

model Combo {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  triggerUrlPattern String // regex veya exact URL
  triggerProductId  String?

  suggestedProductName           String
  suggestedProductPrice          String
  suggestedProductUrl            String
  suggestedProductImageOriginal  String?
  suggestedProductImageProcessed String?

  mascotText  String
  socialProof String?
  expertNote  String?

  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  // pending: ajan kurdu, editör onayı bekliyor (widget'a çıkmaz) | published: yayında
  status    String   @default("published")
  // manual: panelden elle | agent: katalog ajanı kurdu
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events AnalyticsEvent[]

  @@index([customerId, status])
}

// Ajan tarama koşusu — Katalog'daki "Tarama geçmişi" tablosu ve kaynak sağlığı
// trigger: manual (panelden) | scheduled (periyodik fark taraması)
// state: running | done | error
model ScanRun {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  siteUrl         String
  trigger         String @default("manual")
  state           String @default("running")
  pagesScanned    Int    @default(0)
  productsFound   Int    @default(0)
  productsNew     Int    @default(0)
  productsRemoved Int    @default(0)
  combosCreated   Int    @default(0)
  error           String?
  pages           String @default("[]") // taranan sayfa URL'leri (JSON dizi, üst sınırlı)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([customerId, startedAt])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  comboId    String?
  combo      Combo?   @relation(fields: [comboId], references: [id])

  eventType  String
  sessionId  String
  pageUrl    String
  deviceType String? // 'mobile' | 'desktop'
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([comboId, eventType])
}
