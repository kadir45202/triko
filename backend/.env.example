# SQLite ile geliştirme; üretimde PostgreSQL bağlantı dizesi kullanın:
# DATABASE_URL="postgresql://user:pass@host:5432/triko"
DATABASE_URL="file:./dev.db"
JWT_SECRET="degistir-bunu-uretimde"
PORT=4000
# Opsiyonel: Redis (boşsa in-memory cache kullanılır)
# REDIS_URL="redis://localhost:6379"
# Opsiyonel: arkaplan silme servisi (rembg http sunucusu; boşsa görsel olduğu gibi kullanılır)
# REMBG_URL="http://localhost:7000"
# Opsiyonel: AI öneri motoru (boşsa kural bazlı öneri kullanılır)
# ANTHROPIC_API_KEY="sk-ant-..."

# Katalog ajanı (Faz A/B)
# AGENT_RESCAN_MS=21600000   # periyodik fark taraması (ms; 0 = kapalı)
# AGENT_MAX_PAGES=120        # tarama başına sayfa üst sınırı
